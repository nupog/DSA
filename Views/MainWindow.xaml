<Window x:Class="DeepSeekSurveyAnalyzer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DeepSeekSurveyAnalyzer"
        Title="Анализатор опросов DeepSeek" Height="600" Width="850"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с настройками подключения -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
            <Button Content="⚙️ Настройка подключения" 
                    Command="{Binding OpenSettingsCommand}" 
                    Padding="10,5"
                    Background="#F0F0F0"
                    BorderBrush="#CCCCCC"
                    ToolTip="Настройки API ключа и эндпоинта DeepSeek"/>
        </StackPanel>

        <!-- Загрузка файлов -->
        <GroupBox Grid.Row="1" Header="Загрузите результат опроса" Margin="0,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <StackPanel Orientation="Horizontal" Margin="5">
                    <Button Content="Выбрать файлы" Command="{Binding AddFilesCommand}" Padding="10,5"/>
                    <Button Content="Очистить" Command="{Binding ClearFilesCommand}" Margin="10,0,0,0" Padding="10,5"/>
                </StackPanel>
                
                <ListBox Grid.Row="1" 
                         ItemsSource="{Binding SelectedFiles}" 
                         Margin="5" 
                         AllowDrop="True" 
                         Drop="ListBox_Drop" 
                         DragEnter="ListBox_DragEnter">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding}" ToolTip="{Binding}" VerticalAlignment="Center"/>
                                <Button Content="❌" 
                                        Margin="5,0,0,0" 
                                        Command="{Binding DataContext.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                        CommandParameter="{Binding}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="Red"
                                        ToolTip="Удалить"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </GroupBox>

        <!-- Первая строка кнопок - анализ опросов -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,10">
            <Button Content="📊 Отправить отчёт на анализ" 
                    Command="{Binding SendCommand}"
                    Padding="20,10" 
                    Margin="0,0,20,0"
                    FontSize="14"
                    FontWeight="Bold"
                    Background="#0078D4"
                    Foreground="White"
                    BorderThickness="0"
                    MinWidth="250"
                    ToolTip="Отправить файлы в ИИ для анализа"/>
            
            <Button Content="⚙️ Настройка промта" 
                    Command="{Binding OpenPromptSettingsCommand}"
                    Padding="20,10" 
                    FontSize="14"
                    Background="#F0F0F0"
                    BorderBrush="#CCCCCC"
                    MinWidth="150"
                    ToolTip="Настроить текст промта для анализа опросов"/>
        </StackPanel>

        <!-- Вторая строка кнопок - SWOT-анализ -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,10">
            <Button Content="📈 Сформировать SWOT-анализ результатов" 
                    Command="{Binding GenerateSwotCommand}"
                    Padding="20,10" 
                    Margin="0,0,20,0"
                    FontSize="14"
                    FontWeight="Bold"
                    Background="#107C10"
                    Foreground="White"
                    BorderThickness="0"
                    MinWidth="250"
                    ToolTip="Сформировать SWOT-анализ на основе предыдущего анализа"/>
            
            <Button Content="⚙️ Настройка промта" 
                    Command="{Binding OpenSwotPromptSettingsCommand}"
                    Padding="20,10" 
                    FontSize="14"
                    Background="#F0F0F0"
                    BorderBrush="#CCCCCC"
                    MinWidth="150"
                    ToolTip="Настроить текст промта для SWOT-анализа"/>
        </StackPanel>

        <!-- Индикатор прогресса -->
        <Border Grid.Row="4" 
                Background="#FFF0F0F0" 
                CornerRadius="5" 
                Padding="10"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="{Binding ProgressMessage}" 
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,5"/>
                <ProgressBar IsIndeterminate="True" 
                             Height="10" 
                             Margin="0,5,0,0"
                             Foreground="#0078D4"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>